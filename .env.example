# --- Database / queues (docker-compose defaults for local dev) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mission_control
REDIS_URL=redis://localhost:6379

# --- Auth-lite (ARCHITECTURE §4): one user behind a real cookie session ---
# SESSION_SECRET: >=32 chars, encrypts the iron-session cookie
SESSION_SECRET=change-me-to-a-random-string-of-32-plus-chars
# SESSION_PASSWORD: the shared secret typed at /login
SESSION_PASSWORD=change-me

# --- The single owner (seeded by `npm run db:seed`, resolved by the worker) ---
USER_EMAIL=mark@example.com
USER_NAME=Mark

# --- Token sealing (reserved for MC-101; required in prod env from Phase 1) ---
TOKEN_SEAL_KEY=

# --- Email mirror (MC-005) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Mission Control <bot@example.com>"
MAIL_TO=mark@example.com

# --- Web push (MC-006): generate with `npx web-push generate-vapid-keys` ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:mark@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- Web app ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
